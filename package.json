{
  "name": "titisite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Portfolio de Baptiste Niszczota — Développeur créatif & compositeur",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "start": "NODE_ENV=production node server/index.js",
    "seed": "node server/seed.js",
    "test": "node --test 'test/*.test.js'",
    "lint:security": "eslint server/ src/ test/",
    "lint:secrets": "secretlint --maskSecrets \"**/*.{js,jsx,json,yml,yaml,toml,env}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "react": "^18.3.1",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^12.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "secretlint": "^12.3.0",
    "vite": "^8.0.10"
  },
  "lint-staged": {
    "*.{js,jsx}": "eslint",
    "*.{js,jsx,json,yml,yaml,toml}": "secretlint --maskSecrets"
  }
}
