# ── Secrets ──
# JWT signing key. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ── Admin account (full access: /admin + /project) ──
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Baptiste
ADMIN_PASSWORD=change-me-please

# ── Collaborator account (project workspace only) ──
MEMBER_EMAIL=collab@example.com
MEMBER_NAME=Collaborator
MEMBER_PASSWORD=change-me-too

# ── Optional ──
# PORT=3001
# DB_PATH=./data.sqlite
# UPLOADS_DIR=./uploads
# MAX_UPLOAD_BYTES=1073741824
# Set this in production to prevent Host-header injection in generated iCal URLs.
# CANONICAL_ORIGIN=https://yourdomain.com

# ── Email digest (optional) ──
# Without SMTP_HOST, the digest scheduler is a no-op (warning logged at boot).
# Users can still toggle their preference, but no emails will be sent.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey-or-username
# SMTP_PASS=secret
# SMTP_SECURE=false             # true for port 465, false (STARTTLS) otherwise
# SMTP_FROM=Titisite <no-reply@yourdomain.com>
