# ── Secrets ──
# JWT signing key. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ── Admin account (full access: /admin + /project) ──
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Baptiste
ADMIN_PASSWORD=change-me-please

# ── Collaborator account (project workspace only) ──
MEMBER_EMAIL=collab@example.com
MEMBER_NAME=Collaborator
MEMBER_PASSWORD=change-me-too

# ── Optional ──
# PORT=3001
# DB_PATH=./data.sqlite
# UPLOADS_DIR=./uploads
# MAX_UPLOAD_BYTES=1073741824
