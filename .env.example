# ── Secrets ──
# JWT signing key. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ── Admin account (full access: /admin + /project) ──
# Passwords must be at least 12 characters and not on the denylist
# (the placeholders below are deliberately rejected — replace before booting).
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Baptiste
ADMIN_PASSWORD=change-me-please

# ── Collaborator account (project workspace only) ──
MEMBER_EMAIL=collab@example.com
MEMBER_NAME=Collaborator
MEMBER_PASSWORD=change-me-too

# ── Server ──
PORT=3001
DB_PATH=/var/data/titisite/data.sqlite
UPLOADS_DIR=/var/data/titisite/uploads

# REQUIRED in production: prevents Host-header injection in generated iCal URLs.
# The server refuses to boot in NODE_ENV=production without it.
CANONICAL_ORIGIN=https://baptiste-niszczota.com

# ── Email digest (optional) ──
# Without SMTP_HOST, the digest scheduler is a no-op (warning logged at boot).
# Users can still toggle their preference, but no emails will be sent.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey-or-username
# SMTP_PASS=secret
# SMTP_SECURE=false             # true for port 465, false (STARTTLS) otherwise
# SMTP_FROM=Baptiste <no-reply@baptiste-niszczota.com>
